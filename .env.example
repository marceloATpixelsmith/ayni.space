# ============================================================
# SaaS Platform — Environment Variable Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── DATABASE ────────────────────────────────────────────────
# Platform database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/platform_db

# ── SERVER ──────────────────────────────────────────────────
# Port for the API server
PORT=3000

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-here

# Keep secrets in env/secret stores.
# Primary non-secret runtime configuration is DB-backed via platform.settings and platform.app_settings.

# Frontend URL (used for OAuth redirect targets)
FRONTEND_URL=http://localhost:5173

# Canonical allowed origins are derived from active platform.apps.domain values (runtime).
# LEGACY / NON-CANONICAL / OPTIONAL fallback only: comma-separated extra origins.
# Used only to extend (not replace) the DB-derived origin set.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

NODE_ENV=development

# Optional session-group settings
# Session group name for this backend instance (default: default)
SESSION_GROUP=default
# Group-specific cookie names (comma-separated group=cookieName pairs)
SESSION_GROUP_COOKIE_NAMES=default=saas.sid,admin=saas.admin.sid
# Frontend origins that belong to the admin-restricted session group
ADMIN_FRONTEND_ORIGINS=http://localhost:5173

# ── GOOGLE OAUTH ────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set Authorized Redirect URI to: {FRONTEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── STRIPE ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from: stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── TRANSACTIONAL EMAIL (LANE 1 + LANE 2) ─────────────────
# Lane 1 provider selector (currently only "brevo" is supported)
PLATFORM_TRANSACTIONAL_EMAIL_PROVIDER=brevo
# Required in production for Lane 1 invitation email delivery
PLATFORM_BREVO_API_KEY=
# Required for Lane 2 tenant credential encryption/decryption (64 hex chars)
EMAIL_CREDENTIALS_ENCRYPTION_KEY=
# Optional: override API base URLs for provider integrations
BREVO_API_BASE_URL=https://api.brevo.com
MAILCHIMP_TRANSACTIONAL_API_BASE_URL=https://mandrillapp.com
# Optional but recommended in production when webhooks are enabled
BREVO_WEBHOOK_SECRET=
MAILCHIMP_TRANSACTIONAL_WEBHOOK_KEY=
